package example:text-analysis;

interface analyzer {
  record word-stats {
    word: string,
    count: u32,
  }

  record analysis-result {
    total-words: u32,
    unique-words: u32,
    top-words: list<word-stats>,
  }

  analyze: func(text: string, top-n: u32) -> result<analysis-result, string>;
}

world text-analyzer {
  export analyzer;
}
